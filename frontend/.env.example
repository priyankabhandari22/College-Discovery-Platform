# CollegeDB API key — https://collegedb.in/dashboard
# Required for real-time college search.
COLLEGEDB_API_KEY=cdb_your_key_here

# Neon PostgreSQL connection string
# Get from https://neon.tech — required for auth + saved colleges
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# NextAuth secret — generate via: openssl rand -hex 32
AUTH_SECRET=your_random_64_char_hex_string_here

# Google OAuth (optional — leave disabled if not configured)
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxx
